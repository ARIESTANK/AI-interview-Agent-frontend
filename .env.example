# Your Pipecat dev runner's session-start endpoint. The client POSTs here
# first to get a sessionId, then automatically follows up with
# /sessions/{sessionId}/api/offer to complete the WebRTC handshake.
# Both routes are provided by pipecat.runner.run — you don't write them.
VITE_PIPECAT_START_URL=http://localhost:7860/start
